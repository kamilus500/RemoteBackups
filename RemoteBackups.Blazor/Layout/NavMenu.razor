@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using RemoteBackups.Blazor.Providers
@using RemoteBackups.Blazor.Services.Interfaces

@inject ILocalizationService Localizer

<MudNavMenu Class="pa-2">
    <AuthorizeView>
        <Authorized>
            <MudPaper Class="pa-4 mb-4 text-center" Elevation="0" Outlined="true" Style="background-color: var(--mud-palette-background-grey);">
                <MudBadge Color="Color.Success" Overlap="true" Bordered="true" Bottom="true">
                    <MudAvatar Style="height:60px; width:60px; border: 2px solid var(--mud-palette-primary);" Image="images/default-avatar.png" />
                </MudBadge>

                <MudText Typo="Typo.caption" Class="d-block mt-2 text-muted" Style="text-transform: uppercase; letter-spacing: 0.5px;">@Localizer.GetString("Logged_in_as")</MudText>
                <MudText Typo="Typo.subtitle2" Class="fw-bold mb-3 text-truncate" Title="@context.User.Identity?.Name">
                    @context.User.Identity?.Name
                </MudText>

                <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true" StartIcon="@Icons.Material.Filled.Logout" OnClick="LogOut">
                    @Localizer.GetString("Logout")
                </MudButton>
            </MudPaper>
        </Authorized>

        <NotAuthorized>
            <MudPaper Class="pa-4 mb-4 text-center" Elevation="0" Outlined="true" Style="background-color: var(--mud-palette-background-grey);">
                <MudStack Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Login" OnClick="LogIn">
                        @Localizer.GetString("LogIn")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="Register">
                        @Localizer.GetString("Register")
                    </MudButton>
                </MudStack>
            </MudPaper>
        </NotAuthorized>
    </AuthorizeView>

    <MudDivider Class="my-2" />

    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">@Localizer.GetString("Home")</MudNavLink>
    
</MudNavMenu>

@code {
    private async Task LogOut()
    {
        if (AuthStateProvider is CustomAuthStateProvider customProvider)
        {
            await customProvider.NotifyUserLogout();
        }
        Navigation.NavigateTo("/");
    }

    private void LogIn() => Navigation.NavigateTo("/login");
    private void Register() => Navigation.NavigateTo("/register");
}