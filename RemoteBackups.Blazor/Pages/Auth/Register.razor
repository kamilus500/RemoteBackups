@page "/register"
@using RemoteBackups.Blazor.Services.Interfaces

@inject ILocalizationService Localizer

<PageTitle>@Localizer.GetString("Register_title")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center min-vh-100">
    <MudCard Elevation="4" Class="pa-6 w-100 rounded-lg">
        <MudCardContent>
            <MudText Typo="Typo.h4" Align="Align.Center" Color="Color.Primary" Class="mb-6 fw-bold">@Localizer.GetString("Create_account")</MudText>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">@successMessage</MudAlert>
            }

            <EditForm Model="@registerModel" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="registerModel.Login" For="@(() => registerModel.Login)"
                              Label="Login" Variant="Variant.Outlined" Class="mb-4" />

                <MudTextField @bind-Value="registerModel.Password" For="@(() => registerModel.Password)"
                              Label="Hasło" InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-4" />

                <MudTextField @bind-Value="registerModel.ConfirmPassword" For="@(() => registerModel.ConfirmPassword)"
                              Label="Powtórz hasło" InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-6" />

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                           FullWidth="true" Size="Size.Large" Disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">@Localizer.GetString("Register_title")...</MudText>
                    }
                    else
                    {
                        <MudText>@Localizer.GetString("Register")</MudText>
                    }
                </MudButton>
            </EditForm>

            <MudText Align="Align.Center" Typo="Typo.body2" Class="mt-4">
                @Localizer.GetString("Account_question") <MudLink Href="/login" Color="Color.Primary">@Localizer.GetString("LogIn")</MudLink>
            </MudText>

        </MudCardContent>
    </MudCard>
</MudContainer>