@page "/upload"
@implements IDisposable

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<AuthorizeView>
    <Authorized>
        <h3 class="mb-4">@Localizer.GetString("Upload_files") (1GB max)</h3>

        <div class="d-flex align-center gap-3 mb-4">
            <input type="file" id="fileInput" class="d-none" multiple @onchange="HandleFileSelection" />

            <MudButton HtmlTag="label"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.AttachFile"
                       for="fileInput">
                @Localizer.GetString("Select_files")
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.CloudUpload"
                       OnClick="StartUpload"
                       Disabled="@isUploading">
                @Localizer.GetString("Start_upload")
            </MudButton>
        </div>

        @if (!string.IsNullOrEmpty(selectedFilesInfo))
        {
            <MudText Typo="Typo.caption" Class="mb-3">@selectedFilesInfo</MudText>
        }

        @if (isUploading)
        {
            @foreach (var file in fileProgresses)
            {
                <div class="mt-2">
                    <span>@file.Key: @file.Value%</span>
                    <div class="progress">
                        <div class="progress-bar" style="width: @(file.Value)%"></div>
                    </div>
                    @if (fileStatuses.ContainsKey(file.Key))
                    {
                        <small>@fileStatuses[file.Key]</small>
                    }
                </div>
            }
        }

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert alert-info mt-3">@statusMessage</div>
        }
    </Authorized>
    
    <NotAuthorized>
        <div class="alert alert-danger mt-5">
            <h4>@Localizer.GetString("No_access")</h4>
            <p>@Localizer.GetString("You_must_log_in")</p>
        </div>
    </NotAuthorized>
</AuthorizeView>