@page "/upload"
@implements IDisposable

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<AuthorizeView>
    <Authorized>
        <h3>@Localizer.GetString("Upload_files") (1GB max)</h3>
        <div class="mb-3">
            <input type="file" id="fileInput" class="form-control" multiple />
        </div>
        <button class="btn btn-primary" @onclick="StartUpload">@Localizer.GetString("Start_upload")</button>

        @if (isUploading)
        {
            @foreach (var file in fileProgresses)
            {
                <div class="mt-2">
                    <span>@file.Key: @file.Value%</span>
                    <div class="progress">
                        <div class="progress-bar" style="width: @(file.Value)%"></div>
                    </div>
                    @if (fileStatuses.ContainsKey(file.Key))
                    {
                        <small>@fileStatuses[file.Key]</small>
                    }
                </div>
            }
        }

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert alert-info mt-3">@statusMessage</div>
        }
    </Authorized>
    
    <NotAuthorized>
        <div class="alert alert-danger mt-5">
            <h4>@Localizer.GetString("No_access")</h4>
            <p>@Localizer.GetString("You_must_log_in")</p>
        </div>
    </NotAuthorized>
</AuthorizeView>